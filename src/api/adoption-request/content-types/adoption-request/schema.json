{
  "kind": "collectionType",
  "collectionName": "adoption_requests",
  "info": {
    "singularName": "adoption-request",
    "pluralName": "adoption-requests",
    "displayName": "Adoption Request"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "message": {
      "type": "text"
    },
    "adoption_process_agreement": {
      "type": "boolean"
    },
    "applicant": {
      "type": "json"
    },
    "household": {
      "type": "json"
    },
    "employment": {
      "type": "json"
    },
    "housing": {
      "type": "json"
    },
    "outdoor": {
      "type": "json"
    },
    "other_pets": {
      "type": "json"
    },
    "remarks": {
      "type": "text"
    },
    "responsibility_agreement": {
      "type": "boolean"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "pending",
        "in_progress",
        "approved",
        "rejected"
      ],
      "default": "pending"
    },
    "match_score": {
      "type": "integer"
    },
    "request_date": {
      "type": "date"
    },
    "announcement": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::announcement.announcement",
      "inversedBy": "adoption_requests"
    },
    "animal": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::animal.animal"
    },
    "adopter": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "referent": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
