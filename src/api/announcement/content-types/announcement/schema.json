{
  "kind": "collectionType",
  "collectionName": "announcements",
  "info": {
    "singularName": "announcement",
    "pluralName": "announcements",
    "displayName": "Announcement"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "open",
        "closed"
      ],
      "default": "open"
    },
    "animals": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::animal.animal",
      "inversedBy": "announcements"
    },
    "constraints": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::constraint.constraint",
      "inversedBy": "announcements"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag",
      "inversedBy": "announcements"
    },
    "adoption_requests": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::adoption-request.adoption-request",
      "mappedBy": "announcement"
    }
  }
}
