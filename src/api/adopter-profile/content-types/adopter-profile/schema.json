{
  "kind": "collectionType",
  "collectionName": "adopter_profiles",
  "info": {
    "singularName": "adopter-profile",
    "pluralName": "adopter-profiles",
    "displayName": "Adopter Profile"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "housing_type": {
      "type": "enumeration",
      "enum": [
        "house",
        "apartment"
      ]
    },
    "has_garden": {
      "type": "boolean",
      "default": false
    },
    "has_children": {
      "type": "boolean",
      "default": false
    },
    "has_dogs": {
      "type": "boolean",
      "default": false
    },
    "has_cats": {
      "type": "boolean",
      "default": false
    },
    "experience_level": {
      "type": "enumeration",
      "enum": [
        "none",
        "some",
        "experienced"
      ],
      "default": "none"
    },
    "age_preference": {
      "type": "enumeration",
      "enum": ["chaton", "adulte", "senior", "peu_importe"],
      "default": "peu_importe"
    },
    "activity_level_preference": {
      "type": "enumeration",
      "enum": ["low", "medium", "high", "peu_importe"],
      "default": "peu_importe"
    },
    "motivation": {
      "type": "text"
    }
  }
}
