{
  "kind": "collectionType",
  "collectionName": "volunteer_assignments",
  "info": {
    "singularName": "volunteer-assignment",
    "pluralName": "volunteer-assignments",
    "displayName": "Volunteer Assignment"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "volunteer": {
      "type": "relation",
